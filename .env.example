# Foxhound — environment configuration
# Copy to `.env` and fill in your own values. Never commit a real `.env`.

# ── Core ────────────────────────────────────────────────────────────────────
ENVIRONMENT=development                 # development | production
LOG_LEVEL=INFO
APP_BASE_URL=http://127.0.0.1:8000
# Local dev can use SQLite; production uses Postgres (Supabase).
DATABASE_URL=sqlite+aiosqlite:///./foxhound.db
# Comma-separated allowed origins for the web frontend (must not be empty or "*").
FOXHOUND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── LLM (Anthropic) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional model overrides (sensible defaults are baked in):
# FOXHOUND_AGENT_MODEL=
# FOXHOUND_LLM_MODEL=
# FOXHOUND_LLM_MODEL_PREMIUM=
# FOXHOUND_CODEGEN_MODEL_HEAVY=
# FOXHOUND_CODEGEN_MODEL_LIGHT=

# ── Browser automation ──────────────────────────────────────────────────────
TINYFISH_API_KEY=your-tinyfish-key
# TINYFISH_PROXY_URL=
# AGENTQL_KEY=

# ── Supabase (auth, database, storage) ──────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key   # server-side only — keep secret

# ── Channels (optional) ─────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# DISCORD_PUBLIC_KEY=
# TWILIO_AUTH_TOKEN=
# FOXHOUND_SLACK_WEBHOOK_URL=
# FOXHOUND_DISCORD_WEBHOOK_URL=
# FOXHOUND_SMS_WEBHOOK_URL=

# ── Fly.io sandbox previews (optional) ──────────────────────────────────────
# FLY_API_TOKEN=
# FLY_ORG=personal
# FLY_REGION=iad
# FLY_SANDBOX_IMAGE=registry.fly.io/foxhound-sandbox:latest
# Shared secret required by the sandbox upload servers (fail-closed if unset).
# SANDBOX_UPLOAD_TOKEN=

# ── Misc ────────────────────────────────────────────────────────────────────
# FOXHOUND_INTERNAL_TOKEN=
# Dev only — bypasses webhook signature checks. Always ignored in production.
# FOXHOUND_SKIP_WEBHOOK_VERIFY=0
